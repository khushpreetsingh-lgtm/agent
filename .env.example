# ──────────────────────────────────────
# DQE Agent v3 — Environment Configuration
# ──────────────────────────────────────

# --- LLM Provider ---
LLM_PROVIDER=azure
LLM_MODEL=gpt-4o-mini

# --- Model Routing (Planner-Executor-Verifier) ---
# Planner: large model, runs once per task
PLANNER_MODEL=gpt-4o
PLANNER_PROVIDER=                   # empty = use LLM_PROVIDER

# Executor: small/fast model, runs per step
EXECUTOR_MODEL=gpt-4o-mini

# Vision: for screenshot-based verification fallback
VISION_MODEL=gpt-4o

# --- Azure OpenAI ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-01-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# --- OpenAI (direct, if not using Azure) ---
# OPENAI_API_KEY=sk-...

# --- Anthropic ---
ANTHROPIC_API_KEY=
CUA_PROVIDER=anthropic
CUA_MODEL=claude-sonnet-4-20250514

# --- Browser Viewport ---
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=800

# --- NetSuite Credentials ---
NETSUITE_URL=https://your-company.app.netsuite.com
NETSUITE_USERNAME=
NETSUITE_PASSWORD=
# NETSUITE_TOTP_SECRET=

# --- CPQ Credentials ---
CPQ_URL=https://your-cpq-instance.com
CPQ_USERNAME=
CPQ_PASSWORD=

# --- Jira Credentials (browser connector) ---
JIRA_URL=https://your-company.atlassian.net
JIRA_USERNAME=
JIRA_PASSWORD=

# --- Jira API Token (for Jira MCP server) ---
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# --- Email (SMTP) ---
SMTP_HOST=smtp.office365.com
SMTP_PORT=587

# --- Gmail MCP Server (OAuth2) ---
# Create credentials at: https://console.cloud.google.com → APIs & Services → OAuth 2.0 Client IDs
# Scopes needed: https://mail.google.com/
# Run 'npx @gongrzhe/server-gmail-autoauth-mcp' once interactively to complete OAuth and get REFRESH_TOKEN
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=quotes@yourcompany.com

# --- MCP Servers ---
BRAVE_API_KEY=
# JIRA_API_TOKEN is listed above under Jira credentials
# Playwright MCP needs no env vars (uses local Chromium)

# --- Guardrails ---
MAX_STEPS=20
MAX_COST_USD=2.0
TIMEOUT_SECONDS=300

# --- Agent Behavior ---
HEADLESS=false
SCREENSHOT_ENABLED=true
SCREENSHOT_DIR=./screenshots
