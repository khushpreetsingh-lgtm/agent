# ──────────────────────────────────────────────────────────────────────────────
# DQE Agent — Environment Configuration
# Copy this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.
# ──────────────────────────────────────────────────────────────────────────────


# ── LLM: General (Executor / default model) ───────────────────────────────────
# Which provider to use for all LLM calls unless overridden below.
# Options: azure | openai | anthropic
LLM_PROVIDER=azure
LLM_MODEL=gpt-4o-mini


# ── LLM: Planner (large/expensive — runs ONCE per task) ───────────────────────
# The planner thinks deeply to produce a step plan. Use the best model you have.
PLANNER_MODEL=gpt-4o
PLANNER_PROVIDER=                   # leave blank to inherit LLM_PROVIDER


# ── LLM: Executor (small/fast — runs once per step) ───────────────────────────
EXECUTOR_MODEL=gpt-4o-mini


# ── LLM: Vision fallback (screenshot-based verification) ──────────────────────
VISION_MODEL=gpt-4o


# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# Used when LLM_PROVIDER=azure (or PLANNER_PROVIDER=azure)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-01-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini


# ── OpenAI (direct — alternative to Azure) ────────────────────────────────────
# Used when LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...


# ── Anthropic ─────────────────────────────────────────────────────────────────
# Used when LLM_PROVIDER=anthropic, or for the Computer Use Agent (CUA)
ANTHROPIC_API_KEY=
CUA_PROVIDER=anthropic
CUA_MODEL=claude-sonnet-4-20250514


# ── Jira (MCP server — required for all Jira features) ────────────────────────
# Your Atlassian Cloud base URL (no trailing slash)
JIRA_URL=https://your-company.atlassian.net

# The email you use to log into Jira
JIRA_USERNAME=you@yourcompany.com

# API token — generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# Password (only needed if using browser-based Jira login, not API token)
JIRA_PASSWORD=


# ── Google Workspace (Gmail + Calendar MCP server) ────────────────────────────
# Create OAuth credentials at: https://console.cloud.google.com
#   → APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client ID
#   → Application type: Desktop
#   → Download JSON → extract client_id and client_secret
#
# Then run the one-time auth flow to get your refresh token:
#   python setup_google_auth.py
#
# Required OAuth scopes:
#   https://mail.google.com/
#   https://www.googleapis.com/auth/calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Your Gmail address (used to identify your calendar and mailbox)
USER_GOOGLE_EMAIL=you@gmail.com


# ── Gmail via SMTP (outbound email for quote approvals) ───────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=quotes@yourcompany.com


# ── NetSuite (browser automation) ─────────────────────────────────────────────
# Only needed for the Opportunity → Quote workflow
NETSUITE_URL=https://your-company.app.netsuite.com
NETSUITE_USERNAME=
NETSUITE_PASSWORD=
# NETSUITE_TOTP_SECRET=        # uncomment if MFA is enabled


# ── CPQ (browser automation) ──────────────────────────────────────────────────
# Only needed for the Opportunity → Quote workflow
CPQ_URL=https://your-cpq-instance.com
CPQ_USERNAME=
CPQ_PASSWORD=


# ── Brave Search MCP (web search tool) ────────────────────────────────────────
# Get an API key at: https://api.search.brave.com
# Enable the server in mcp_config.yaml (enabled: true)
BRAVE_API_KEY=


# ── Browser viewport ──────────────────────────────────────────────────────────
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=800

# Set HEADLESS=true to run without a visible browser window (e.g. on a server)
HEADLESS=false
SCREENSHOT_ENABLED=true
SCREENSHOT_DIR=./screenshots

# Set to true to disable all Playwright browser tools.
# When true the agent uses only MCP tools (Jira, Gmail, Calendar).
# Useful if you only need Jira/email and don't want Playwright overhead.
DISABLE_BROWSER_TOOLS=false


# ── Guardrails ────────────────────────────────────────────────────────────────
# Hard limits per task to prevent runaway agents
MAX_STEPS=20            # max agent steps before forced stop
MAX_COST_USD=2.0        # max estimated LLM spend per task (USD)
TIMEOUT_SECONDS=300     # max wall-clock seconds per task
